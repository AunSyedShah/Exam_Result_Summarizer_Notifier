# Email Configuration (Gmail or custom SMTP)
# Leave empty for demo mode (emails logged to console)
EMAIL_ADDRESS=your-email@example.com
EMAIL_PASSWORD=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Hugging Face API Configuration
# Get your free API key from: https://huggingface.co/settings/tokens
# Create a fine-grained token with 'repo.read' permission
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx

# Hugging Face Model Selection (uses Chat Completion API)
# Models verified to work on HF Inference API free tier:
# - llama-3.3: High quality output (meta-llama/Llama-3.3-70B-Instruct) ← RECOMMENDED
# - mistral: Fast & reliable (mistralai/Mistral-7B-Instruct-v0.2)
# - zephyr: Instruction-tuned (HuggingFaceH4/zephyr-7b-beta)
# - deepseek-r1: Advanced reasoning (deepseek-ai/DeepSeek-R1) [verbose with thinking tags]
# - flan-t5: Fallback option (google/flan-t5-base)
HF_MODEL=llama-3.3

# Flask Configuration
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
